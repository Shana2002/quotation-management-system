# Deny execution of any scripts inside the uploads directory.
# Only allow static asset types to be served.
<IfModule mod_php.c>
    php_flag engine off
</IfModule>
<IfModule mod_php7.c>
    php_flag engine off
</IfModule>
<IfModule mod_php8.c>
    php_flag engine off
</IfModule>

# Block direct access to executable/script files.
<FilesMatch "\.(php|php3|php4|php5|php7|php8|phtml|pl|py|cgi|asp|sh|exe)$">
    Require all denied
</FilesMatch>
